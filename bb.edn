;; bb.edn — task entry points for nu_plugin_edn.
;;
;; The plugin itself uses only libraries bundled with babashka
;; (clojure.edn, cheshire), so no :deps are needed here. This file
;; exists to give contributors a familiar `bb <task>` interface.

{:min-bb-version "1.3.0"

 :tasks
 {test
  {:doc  "Run the Nushell integration tests. Requires the plugin to have been registered with `bb register` first."
   :task (shell "nu nu_plugin_edn.tests.nu")}

  register
  {:doc  "Register the plugin with Nushell (persists to plugin.msgpackz)."
   :task (shell "nu -c \"plugin add ./nu_plugin_edn\"")}

  lint
  {:doc  "Lint the plugin source with clj-kondo. The plugin file has no extension, so we hint --lang clj."
   :task (shell "clj-kondo --lint nu_plugin_edn --lang clj")}

  fmt
  {:doc  "Apply cljfmt formatting to the plugin source (mutates the file)."
   :task (shell "cljfmt fix nu_plugin_edn")}

  fmt-check
  {:doc  "Verify cljfmt formatting without modifying the file. Non-zero exit on any diff."
   :task (shell "cljfmt check nu_plugin_edn")}

  check
  {:doc     "Run lint and fmt-check together. The 'always run before committing' task."
   :depends [lint fmt-check]}

  release-check
  {:doc  "Refuse to release a SNAPSHOT version. Run before `git tag`."
   :task (let [src (slurp "nu_plugin_edn")
               m   (re-find (re-pattern "\\(def plugin-release\\s+\"([^\"]+)\"") src)
               ver (second m)]
           (cond
             (nil? ver)
             (do (println "ERROR: couldn't parse plugin-release from source")
                 (System/exit 1))

             (re-find (re-pattern "-SNAPSHOT") ver)
             (do (println "ERROR: plugin-release is" (str "\"" ver "\"")
                          "— refusing to release a SNAPSHOT version.")
                 (println "       Drop the -SNAPSHOT suffix in nu_plugin_edn before tagging.")
                 (System/exit 1))

             :else
             (println "OK: plugin-release is" (str "\"" ver "\""))))}}}
