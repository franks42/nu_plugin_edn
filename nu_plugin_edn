#!/usr/bin/env bb
;; nu_plugin_edn — Nushell plugin providing `from edn`.
;;
;; This is the working prototype from the design conversation. It handles
;; the protocol handshake, basic scalars, maps, vectors, sets, and lists.
;;
;; Known limitations (see CLAUDE.md for the full list):
;;   - Keywords lose round-trip fidelity: `:file` -> "file" (colon dropped).
;;     A `--keep-keyword-prefix` flag is planned for opt-in fidelity.
;;   - No tagged-literal support beyond what edn/read-string handles natively
;;   - `to edn` emits compact form via pr-str. Pretty-printing, --meta, and
;;     --keep-keyword-prefix flags are planned (see CLAUDE.md roadmap).
;;   - Nushell-native types without an EDN equivalent (Duration, Filesize,
;;     Binary, etc.) emit primitive fallbacks: ms ints, byte ints, base64
;;     strings. Best-effort, lossy, documented in README.
;;
;; Input handling:
;;   - String values (`'edn-text' | from edn`)            -> direct
;;   - ByteStream + single-form mode                       -> buffered to
;;     a string, then parsed. Whole-document, memory grows with input.
;;   - ByteStream + --lines/--objects                      -> truly
;;     incremental: bytes are pulled on demand, forms parsed and emitted
;;     one at a time, engine Drop on the output stream stops further
;;     reads. Required for unbounded producers (`tail -f`) and for
;;     bounded but very large inputs combined with downstream `first N`.

(require '[clojure.edn :as edn]
         '[clojure.pprint :as pprint]
         '[cheshire.core :as json])

(defn log [& args]
  (binding [*out* *err*]
    (apply println "[nu_plugin_edn]" args) (flush)))

;; Step 1: declare encoding to Nushell. Format: <byte-len><encoding-name>.
;; "json" is 4 bytes, prefixed by the length byte 4.
(let [out System/out]
  (.write out (int 4))
  (.write out (.getBytes "json" "UTF-8"))
  (.flush out))

(defn send-msg [m]
  (println (json/generate-string m))
  (flush))

(defn read-msg []
  (when-let [line (read-line)]
    (json/parse-string line true)))

;; Two version constants — they answer different questions.
;;
;; `nushell-target` is what we send in Hello. Nushell does a strict
;; equality check on it; if it doesn't match the running Nushell's
;; version exactly, registration fails. CI sweeps versions by setting
;; the env var; the hardcoded fallback is the project's anchored
;; release version.
;;
;; `plugin-release` is what we send in :Metadata. It's our own release
;; identity, decoupled from the protocol negotiation. During dev
;; windows it carries a `-SNAPSHOT` suffix so users running `plugin list`
;; can tell whether they're on a tagged release or in-flight code.
;; The pre-tag `bb release-check` task refuses to ship a SNAPSHOT.
(def nushell-target
  (or (System/getenv "NU_PLUGIN_EDN_NU_VERSION") "0.112.2"))

(def plugin-release "0.112.2-3-SNAPSHOT")

;; Step 2: Hello exchange. We send first.
(send-msg {:Hello {:protocol "nu-plugin"
                   :version  nushell-target
                   :features []}})
(let [hello (read-msg)]
  (log "got Hello:" (boolean hello)))

;; Step 3: classify incoming control messages — they're not all maps.
;; After a stream-y Run completes, leftover Data/End messages may arrive
;; for input or output streams (especially when we exited early via Drop
;; before the producer finished). Classify them all as :stream-ctl so
;; the main loop drops them on the floor without log noise.
(defn classify [msg]
  (cond
    (nil? msg)                                 :eof
    (= "Goodbye" msg)                          :goodbye
    (and (map? msg) (contains? msg :Call))     :call
    (and (map? msg) (contains? msg :Goodbye))  :goodbye
    (and (map? msg) (contains? msg :Ack))      :stream-ctl
    (and (map? msg) (contains? msg :Drop))     :stream-ctl
    (and (map? msg) (contains? msg :Data))     :stream-ctl
    (and (map? msg) (contains? msg :End))      :stream-ctl
    :else                                      :unknown))

;; Convert a parsed Clojure value into Nushell's value-record shape.
;; Each leaf carries a `span` (Nushell wants source-span info even for
;; values that didn't come from source — `{:start 0 :end 0}` is fine).
;;
;; Dynamic var `*set-as-record*` (bound by handle-from-edn when the
;; user passes --set2record): when true, EDN sets are emitted as
;; Nushell records in mirror form ({k: k} where each key equals its
;; stringified element). Pairs with `to edn --record2set` for round-
;; trip. Default (false) → sets become Nushell lists.
(def ^:dynamic *set-as-record* false)

;; Dynamic var `*keep-keyword-prefix*` (bound by handle-from-edn AND
;; handle-to-edn when --keep-keyword-prefix is on): when true,
;; keyword/string fidelity is preserved across a round-trip by keeping
;; the leading `:` as a marker on the Nushell-side string.
;;   from edn --keep-keyword-prefix:  :foo  -> ":foo"   (string)
;;                                    "bar" -> "bar"    (string)
;;   to   edn --keep-keyword-prefix:  ":foo" -> :foo    (keyword)
;;                                    "bar"  -> "bar"   (string)
;; Heuristic: a string emits as a keyword iff it matches the keyword
;; shape (`:` followed by valid name chars). Plain strings starting
;; with `:` would coerce to keywords on the to-edn side; this is a
;; documented one-way fidelity loss in exchange for round-trip of
;; legitimate keywords. Pair both flags for full round-trip.
(def ^:dynamic *keep-keyword-prefix* false)

;; Dynamic var `*string-keys*` (bound by handle-to-edn when --string-keys
;; is on): when true, record keys emit as strings (`{"name" ...}`)
;; instead of keywords (`{:name ...}`). Useful for pipelines feeding
;; non-Clojure EDN consumers (Python, JS, Go) that don't speak
;; keyword-keys. --keep-keyword-prefix's effect on keys is suppressed
;; under --string-keys (string-keyed output is the goal); the value-side
;; effect of --keep-keyword-prefix still works independently.
(def ^:dynamic *string-keys* false)

;; Pragmatic check: ":foo", ":foo/bar", ":foo.bar-baz", etc. Rejects
;; ":" alone, ":foo bar" (whitespace), ":\"foo\"" (quotes). Doesn't
;; aim for full EDN spec compliance — just a heuristic for whether a
;; string the user typed as ":foo" looks like a keyword they want
;; emitted as one.
(def ^:private keyword-shaped-re
  #":[^\s\"\(\)\[\]\{\}\\,;]+")

(defn- keyword-shaped? [^String s]
  (boolean (re-matches keyword-shaped-re s)))

(defn- set-element-key
  "Stringify a set element to its mirror-record key. EDN keywords drop
  the leading colon (matching the rest of our keyword convention);
  strings stay as-is; everything else falls back to `pr-str`."
  [item]
  (cond
    (keyword? item) (subs (str item) 1)
    (string? item)  item
    :else           (pr-str item)))

(defn ->nu-value [v]
  (let [span {:start 0 :end 0}]
    (cond
      (nil? v)        {:Nothing {:span span}}
      (string? v)     {:String  {:val v :span span}}
      (boolean? v)    {:Bool    {:val v :span span}}
      (integer? v)    {:Int     {:val v :span span}}
      (float? v)      {:Float   {:val (double v) :span span}}
      (keyword? v)    {:String  {:val (if *keep-keyword-prefix*
                                        (str v)
                                        (subs (str v) 1))
                                 :span span}}
      (symbol? v)     {:String  {:val (str v) :span span}}
      ;; #inst literal — clojure.edn parses #inst into java.util.Date by
      ;; default; surface it as a Nushell Date so downstream pipelines
      ;; can use date filters (`format date`, comparisons, etc.).
      (instance? java.util.Date v)
      {:Date {:val (.toString (.toInstant ^java.util.Date v)) :span span}}
      ;; #uuid literal — Nushell has no UUID type; emit as a string so
      ;; downstream `into uuid`/`is-uuid`/string-ops work normally.
      (instance? java.util.UUID v)
      {:String {:val (str v) :span span}}
      (map? v)        {:Record  {:val (into {} (for [[k vv] v]
                                                 [(cond
                                                    (and *keep-keyword-prefix* (keyword? k)) (str k)
                                                    (keyword? k)                              (subs (str k) 1)
                                                    :else                                     (str k))
                                                  (->nu-value vv)]))
                                 :span span}}
      (sequential? v) {:List    {:vals (mapv ->nu-value v) :span span}}
      (set? v)
      (if *set-as-record*
        ;; Mirror form: {k: k} for each set element. Round-trips via
        ;; `to edn --record2set` for keyword/string sets. Lossy for
        ;; non-string elements (Nushell record keys are strings only).
        {:Record {:val (into {} (for [item v]
                                  (let [k (set-element-key item)]
                                    [k {:String {:val k :span span}}])))
                  :span span}}
        {:List {:vals (mapv ->nu-value v) :span span}})
      :else           {:String  {:val (pr-str v) :span span}})))

;; Inverse of ->nu-value: convert a Nushell wire-protocol Value back to
;; a Clojure value suitable for `pr-str` to emit as EDN.
;;
;; Type policy (best-effort fallbacks for types EDN doesn't natively
;; represent — documented in CLAUDE.md and README):
;;   - Nothing               -> nil
;;   - String/Bool/Int/Float -> identity
;;   - Date                  -> java.util.Date (pr-str emits as #inst)
;;   - Duration (nanoseconds)-> integer milliseconds
;;   - Filesize (bytes)      -> integer bytes
;;   - Binary                -> base64-encoded string
;;   - Record                -> Clojure map with keyword keys (the
;;                              JSON-parsed input already gives us
;;                              keywords for free)
;;   - List                  -> Clojure vector
;;   - Range / Closure / CellPath / CustomValue / Error -> string
;;     fallback marked with `#<...>` so the user sees what was lost
;;
;; Dynamic var `*record-as-set*` (bound by handle-to-edn when the user
;; passes --record2set): when true, a Record whose entries are all
;; "mirror form" (keyword key whose name equals the string value) is
;; converted to a Clojure set instead of a map. Round-trip pair with
;; `from edn --set2record`. Default (false) → records always become
;; maps. The check is per-record (per-call), so nested records each
;; get evaluated independently.
(def ^:dynamic *record-as-set* false)

(defn- record-mirror-form?
  "True iff every entry of m is a [keyword string] pair where (name k) == v.
  This is the convention that `from edn --set2record` produces and that
  `to edn --record2set` opts to interpret as a set."
  [m]
  (and (seq m)
       (every? (fn [[k v]]
                 (and (keyword? k) (string? v) (= (name k) v)))
               m)))

(defn nu->clj [v]
  (cond
    (contains? v :Nothing)  nil
    (contains? v :String)
    (let [s (get-in v [:String :val])]
      (if (and *keep-keyword-prefix* (keyword-shaped? s))
        (keyword (subs s 1))
        s))

    (contains? v :Bool)     (get-in v [:Bool :val])
    (contains? v :Int)      (get-in v [:Int :val])
    (contains? v :Float)    (get-in v [:Float :val])

    (contains? v :Date)
    (java.util.Date/from
     (java.time.Instant/parse (get-in v [:Date :val])))

    (contains? v :Duration)
    ;; Nushell durations are nanoseconds; ms is the most universally
    ;; useful integer representation. Truncates sub-ms precision.
    (long (/ (get-in v [:Duration :val]) 1000000))

    (contains? v :Filesize)
    (get-in v [:Filesize :val])

    (contains? v :Binary)
    (.encodeToString (java.util.Base64/getEncoder)
                     (byte-array (mapv unchecked-byte
                                       (get-in v [:Binary :val]))))

    (contains? v :Record)
    ;; Cheshire parses JSON object keys as Clojure keywords; (name k)
    ;; gives back the original Nushell record-key string. Key handling
    ;; precedence:
    ;;   --string-keys                wins → emit as Clojure string.
    ;;   --keep-keyword-prefix on ":foo" → strip marker, emit as :foo.
    ;;   default                          → keep cheshire's keyword as-is
    ;;                                       (pr-str emits as keyword).
    (let [convert-key (fn [k]
                        (cond
                          *string-keys*
                          (if (keyword? k) (name k) (str k))

                          (and *keep-keyword-prefix*
                               (keyword? k)
                               (keyword-shaped? (name k)))
                          (keyword (subs (name k) 1))

                          :else k))
          m (into {} (for [[k vv] (get-in v [:Record :val])]
                       [(convert-key k) (nu->clj vv)]))]
      (if (and *record-as-set* (record-mirror-form? m))
        ;; Mirror-form record + --record2set flag → emit as a set of
        ;; keywords (one per key). Treats the convention as "the
        ;; record represents a keyword set."
        (set (keys m))
        m))

    (contains? v :List)
    (mapv nu->clj (get-in v [:List :vals]))

    :else
    (str "#<" (some-> v keys first name) ">")))

;; ByteStream input handling.
;;
;; When the user pipes an external command into `from edn`, Nushell
;; declares the input as a ByteStream (carrying a stream id) in the Run
;; call, then pushes raw bytes via subsequent `Data` messages — each
;; shaped like {:Data [<stream-id> {:Raw {:Ok [<byte-ints>...]}}]} —
;; terminated by {:End <stream-id>}. We acknowledge each chunk with
;; {:Ack <stream-id>} so the engine's backpressure window keeps moving;
;; otherwise large inputs would stall. Once we see End we decode the
;; accumulated bytes as UTF-8 and return the resulting string for
;; edn/read-string. This is a buffered approach — the entire stream
;; lands in memory before parsing — appropriate for typical config-
;; sized inputs but not for log-sized ones.
;; ----------------------------------------------------------------
;; Concurrent-Call routing (single-threaded).
;;
;; Nushell pipelines plugin Calls concurrently. In `bb ... | from edn
;; --lines | to edn --lines | from edn --lines`, three plugin Calls
;; are in flight at once and the engine routes data between them via
;; the same stdin/stdout channel. While we're processing Call A,
;; messages destined for Calls B and C arrive on stdin:
;;
;;   - :Call(B) — the next plugin command to run.
;;   - :Data/:End for B's input stream — values that Call A produced
;;     for its output stream, looped back as B's input.
;;
;; Our plugin runs Calls serially (one at a time), so messages for
;; not-yet-running Calls have to be buffered, not discarded. Two
;; buffers handle this:
;;
;;   pending-calls   — vec of :Call messages waiting to be dispatched.
;;                     Drained by the main loop before it reads stdin.
;;   stream-buffers  — map of stream-id -> vec of :Data/:End messages
;;                     for streams not yet being read. Drained by
;;                     pull-stream-msg when the relevant Call eventually
;;                     reads from that stream.
;;
;; Without the second buffer, Call B's input data gets lost because
;; Call A's stream readers see :Data with a foreign stream id and
;; recur past it on the way to A's own input.
(def pending-calls (atom []))
(defn queue-call! [msg] (swap! pending-calls conj msg))

(def stream-buffers (atom {}))

(defn- buffer-stream-msg! [msg]
  (when-let [id (cond
                  (contains? msg :Data) (first (:Data msg))
                  (contains? msg :End)  (:End msg))]
    (swap! stream-buffers update id (fnil conj []) msg)))

(defn- pop-buffered-stream-msg! [stream-id]
  (when-let [buf (get @stream-buffers stream-id)]
    (when (seq buf)
      (swap! stream-buffers update stream-id #(vec (rest %)))
      (first buf))))

(defn pull-stream-msg
  "Get the next :Data or :End message for stream-id. Pulls from the
   per-stream buffer first; otherwise reads stdin, routing other
   messages along the way (foreign stream traffic -> stream-buffers,
   :Call -> pending-calls, :Drop on out-sid -> out-state, :Ack/other
   silently discarded). Returns nil on EOF.

   `out-state` is an atom for emit-stream-incremental's drop tracking;
   pass nil from readers that don't have an output stream open."
  [stream-id out-state]
  (or (pop-buffered-stream-msg! stream-id)
      (loop []
        (let [msg (read-msg)]
          (cond
            (nil? msg) nil

            (and (map? msg) (contains? msg :Data))
            (let [[id _] (:Data msg)]
              (if (= id stream-id)
                msg
                (do (buffer-stream-msg! msg) (recur))))

            (and (map? msg) (contains? msg :End))
            (if (= (:End msg) stream-id)
              msg
              (do (buffer-stream-msg! msg) (recur)))

            (and (map? msg) (contains? msg :Call))
            (do (queue-call! msg) (recur))

            (and (map? msg) (contains? msg :Drop))
            (do (when (and out-state
                           (= (:Drop msg) (:out-sid @out-state)))
                  (swap! out-state assoc :dropped? true))
                (recur))

            (and (map? msg) (contains? msg :Ack))
            (recur)

            :else
            (do (log "pull-stream-msg ignoring:"
                     (when (map? msg) (keys msg)))
                (recur)))))))

(defn read-byte-stream [stream-id]
  (let [baos (java.io.ByteArrayOutputStream.)]
    (loop []
      (let [msg (pull-stream-msg stream-id nil)]
        (cond
          (nil? msg)                  (.toString baos "UTF-8")
          (contains? msg :End)        (.toString baos "UTF-8")
          (contains? msg :Data)
          (let [[_ data] (:Data msg)]
            (when-let [bs (get-in data [:Raw :Ok])]
              (doseq [b bs] (.write baos (int b))))
            (send-msg {:Ack stream-id})
            (recur)))))))

;; ListStream output handling (--lines / --objects mode).
;;
;; In multi-form mode we don't return a single Value; we open a ListStream
;; and push parsed forms as Data messages. This lets downstream commands
;; like `first 10` short-circuit instead of waiting for the whole input
;; to be parsed and assembled into a List.
;;
;; Stream ids must be unique within the plugin process. We allocate from
;; an atom that starts at zero — the plugin's id space is independent
;; from the engine's, since direction disambiguates the channel.
(def next-stream-id (atom 0))
(defn alloc-stream-id [] (swap! next-stream-id inc))

;; Source-span computation for parse errors.
;;
;; clojure.edn's parser doesn't expose the failing position directly,
;; but a LineNumberingPushbackReader does — even after the parser
;; throws, .getLineNumber/.getColumnNumber give the reader's last
;; position. Translating that (1-indexed line, 1-indexed col) into a
;; 0-indexed char offset, then into a UTF-8 byte offset, lets us point
;; the Nushell error label at the offending location in the user's
;; source.
;;
;; Scope: only Value-input parse errors get labels, because those are
;; the only ones with a meaningful source span pointing into the
;; user's script. ByteStream input came from an external producer's
;; stdout, so no script-level span exists; we omit labels there.
(defn- char-offset-in
  "Convert (line, col) from a LineNumberingPushbackReader into a
  0-indexed character offset in `s`. Both line and col are 1-indexed
  on the reader. Caps at end-of-string for safety."
  [^String s line col]
  (let [n (.length s)]
    (loop [idx 0, ln 1, cl 1]
      (cond
        (>= idx n)                            idx
        (and (= ln line) (= cl col))          idx
        (= \newline (.charAt s idx))          (recur (inc idx) (inc ln) 1)
        :else                                 (recur (inc idx) ln (inc cl))))))

(defn- byte-offset-of-char
  "UTF-8 byte length of the prefix of s up to char-offset chars."
  [^String s char-offset]
  (let [end (min char-offset (.length s))]
    (alength (.getBytes ^String (subs s 0 end) "UTF-8"))))

;; Read EDN forms from a string with line/col tracking. `multi?` true
;; reads zero-or-more top-level forms (--lines mode); `multi?` false
;; reads exactly one (default). Returns {:ok forms-or-value} or
;; {:err {:line N :col M :cause Throwable}}.
;;
;; We deliberately use form boundaries (matching brackets, quoted
;; strings, etc.) rather than newlines: EDN forms are self-delimiting,
;; multi-line forms parse correctly, and `; comments` work because
;; edn/read strips them. The tradeoff is that one giant top-level form
;; forces the whole stream into memory — but well-behaved producers
;; emit small forms.
(defn- read-edn-with-pos [s multi?]
  (let [reader (clojure.lang.LineNumberingPushbackReader.
                (java.io.StringReader. s))
        eof    (Object.)]
    (try
      (if multi?
        (loop [acc []]
          (let [v (edn/read {:eof eof} reader)]
            (if (= v eof)
              {:ok acc}
              (recur (conj acc v)))))
        ;; Single-form: preserve `edn/read-string ""` => nil; only a
        ;; non-empty empty parse counts as "parsed nothing".
        (let [v (edn/read {:eof eof} reader)]
          {:ok (if (= v eof) nil v)}))
      (catch Throwable t
        {:err {:line  (.getLineNumber reader)
               :col   (.getColumnNumber reader)
               :cause t}}))))

;; Detect a switch by name in the call's :named entries. Each entry is
;; a [{:item "name" :span ...} value] pair; we only care about presence.
(defn flag-set? [named flag-name]
  (some (fn [[k _v]] (= (:item k) flag-name)) named))

;; Fetch a flag's typed-value argument by name. Returns the Nushell
;; Value record (e.g. {:Record {:val ... :span ...}}) or nil if the
;; flag wasn't passed or was passed as a switch with no value.
(defn flag-value [named flag-name]
  (some (fn [[k v]] (when (= (:item k) flag-name) v)) named))

;; Emit a sequence of values as a ListStream response. Each value goes
;; out as {:Data [id {:List <nu-value>}]}, terminated by {:End id}.
;;
;; v1 limitation: we don't wait on engine Acks before sending the next
;; Data, and we don't react to Drop messages mid-stream. For moderate
;; streams the engine tolerates this; large streams may eventually need
;; backpressure. If the engine sends Drop after enough downstream
;; consumption (e.g. `| first 10`), the message will be processed in
;; the main loop after End — harmless but means we still computed and
;; sent every value. True early-termination requires interleaving stdin
;; reads with output writes, which is deferred.
(defn emit-list-stream [call-id forms]
  (let [sid  (alloc-stream-id)
        span {:start 0 :end 0}]
    (send-msg {:CallResponse
               [call-id
                {:PipelineData
                 {:ListStream {:id sid :span span :metadata nil}}}]})
    (doseq [v forms]
      (send-msg {:Data [sid {:List (->nu-value v)}]}))
    (send-msg {:End sid})))

;; ----------------------------------------------------------------
;; True input-side streaming for `--lines` / `--objects` over a
;; ByteStream. (For the buffered single-form path, see read-byte-stream
;; above; for the buffered list-output path, see emit-list-stream above.)
;;
;; Approach: a custom java.io.InputStream pulls bytes on demand from
;; engine `:Data` messages. We chain it through InputStreamReader (UTF-8)
;; and PushbackReader so that `clojure.edn/read` can parse forms one at
;; a time over the live stream, even when a single form spans multiple
;; `:Data` chunks. After each form we emit a `:Data` with the parsed
;; value to our own output ListStream. When the producer's `:End`
;; arrives, the InputStream returns -1 and edn/read returns the eof
;; marker; we then send our own `:End` to close the output.
;;
;; The same stdin channel that delivers our input bytes also delivers
;; control messages for our output (engine `:Drop` when downstream
;; short-circuits, `:Ack` for backpressure tokens). The refill loop
;; demultiplexes: it identifies messages by tag and stream id, queues
;; output-control state in an atom that the emit loop can inspect, and
;; only returns when input bytes (or input EOF) have arrived.
;;
;; Concurrency: single-threaded. Refill blocks on `read-msg`, so we
;; only see `:Drop` between forms (specifically: when we next try to
;; refill input after emitting a form). That's a fine granularity for
;; the `| first N` pattern — we'll stop within a form or two — but
;; means we can't cancel a producer that's in the middle of writing a
;; very large single form.

(defn- bytes-from-data [data]
  ;; data is {:Raw {:Ok [byte-ints...]}} from serde of Result<Vec<u8>>.
  ;; JSON ints are 0-255; convert to signed Java bytes via unchecked-byte.
  (when-let [bs (get-in data [:Raw :Ok])]
    (byte-array (mapv unchecked-byte bs))))

(defn- refill-stream-input! [current eof? in-sid out-state]
  ;; Pull one message for our input stream. pull-stream-msg routes
  ;; foreign stream traffic, Calls, and output Drop along the way.
  (let [msg (pull-stream-msg in-sid out-state)]
    (cond
      (nil? msg)           (reset! eof? true)
      (contains? msg :End) (reset! eof? true)
      (contains? msg :Data)
      (let [[_ data] (:Data msg)]
        (reset! current
                (java.io.ByteArrayInputStream. (bytes-from-data data)))
        (send-msg {:Ack in-sid})))))

(defn- make-incremental-input-stream [in-sid out-state]
  ;; bb's `proxy` doesn't fall through to JDK default impls — every
  ;; method InputStreamReader calls must be implemented here, including
  ;; the no-arg read(), the multi-arg read variants, and `available`
  ;; (which InputStreamReader's StreamDecoder consults).
  ;;
  ;; The 1-arg read delegates to the 3-arg form; the 3-arg form uses
  ;; read-byte! for the first byte (refilling if needed) and then drains
  ;; the current chunk without re-blocking, so a single InputStreamReader
  ;; pull doesn't sit on read-msg waiting for the producer's next chunk
  ;; once we've got data to return.
  (let [current (atom (java.io.ByteArrayInputStream. (byte-array 0)))
        eof?    (atom false)
        read-byte!
        (fn []
          (loop []
            (let [b (.read ^java.io.ByteArrayInputStream @current)]
              (cond
                (>= b 0) b
                @eof?    -1
                :else (do (refill-stream-input! current eof? in-sid out-state)
                          (recur))))))]
    (proxy [java.io.InputStream] []
      (read
        ([]
         (read-byte!))
        ([^bytes buf]
         (.read ^java.io.InputStream this buf 0 (alength buf)))
        ([^bytes buf ^long off ^long len]
         (if (zero? len)
           0
           (let [first (read-byte!)]
             (if (= first -1)
               -1
               (do (aset-byte buf off (unchecked-byte first))
                   ;; Bulk-drain the current BAIS in one System.arraycopy
                   ;; instead of looping byte-by-byte through the sci/Java
                   ;; boundary — at 100K records this is ~5x faster.
                   (let [more (.read ^java.io.ByteArrayInputStream @current
                                     buf (inc off) (dec len))]
                     (if (>= more 0) (+ 1 more) 1))))))))
      (available []
        ;; Bytes available without blocking = whatever's left in the
        ;; current BAIS chunk. (We can't know what the producer will
        ;; send next without reading a message, which would block.)
        (.available ^java.io.ByteArrayInputStream @current))
      (close []
        ;; No-op — stdin is owned by the main loop, not us.
        nil))))

;; Build a Nushell Value::Error suitable for inline emission inside a
;; ListStream. The protocol can't switch a ListStream into an Error
;; response mid-flight, so the only way to surface a parse failure
;; that occurs after we've started emitting :Data is to emit the
;; error AS a list element. ShellError serializes as LabeledError
;; (same shape as our top-level error response), so the inner :error
;; map mirrors the field set in send-error-response.
(defn- error-value [msg]
  {:Error {:error {:msg    msg
                   :labels []
                   :code   nil
                   :url    nil
                   :help   nil
                   :inner  []}
           :span  {:start 0 :end 0}}})

(defn emit-stream-incremental [call-id in-sid]
  (let [out-sid    (alloc-stream-id)
        out-state  (atom {:out-sid out-sid :dropped? false})
        in-stream  (make-incremental-input-stream in-sid out-state)
        reader     (java.io.PushbackReader.
                    (java.io.InputStreamReader. in-stream "UTF-8"))
        eof-marker (Object.)
        span       {:start 0 :end 0}
        input-eof? (atom false)]
    (send-msg {:CallResponse
               [call-id
                {:PipelineData
                 {:ListStream {:id out-sid :span span :metadata nil}}}]})
    (try
      (loop []
        (when-not (:dropped? @out-state)
          (let [v (edn/read {:eof eof-marker} reader)]
            (if (= v eof-marker)
              (reset! input-eof? true)
              (do (send-msg {:Data [out-sid {:List (->nu-value v)}]})
                  (recur))))))
      (catch Throwable t
        ;; Mid-stream parse error: we already opened a ListStream, so
        ;; we can't switch to an :Error response. Emit a Value::Error
        ;; as the final list element so downstream sees the failure
        ;; inline (and `try/catch` can pick it up). Log to stderr too
        ;; for visibility during debugging. Unwrap the cause to get
        ;; the readable message — clojure.edn wraps inner exceptions
        ;; in EdnReader$ReaderException which prefixes with the class
        ;; name in .getMessage.
        (let [inner (or (some-> (.getCause t) .getMessage) (.getMessage t))
              msg   (str "EDN parse error: " inner)]
          (log "parse error during incremental streaming:" msg)
          (send-msg {:Data [out-sid {:List (error-value msg)}]}))))
    ;; If we exited before the producer's End — i.e. `| first N` Drop'd
    ;; us early — tell the engine to tear down the producer. For an
    ;; unbounded source like `tail -f`, this is the only way to make it
    ;; stop. Engine acknowledges by sending End on the input stream;
    ;; remaining in-flight :Data messages will be classified as
    ;; :stream-ctl in the main loop.
    (when-not @input-eof?
      (send-msg {:Drop in-sid}))
    (send-msg {:End out-sid})))

;; Pull the EDN text out of whatever pipeline shape Nushell handed us,
;; along with the source span of the literal it came from (when known).
;; Three shapes show up in practice:
;;   - "Empty"               — no upstream input; "" + nil span
;;   - {:Value [v meta]}      — a single in-memory Value; span is the
;;                              source span of the original String node
;;   - {:ByteStream {:id N}}  — an external command's stdout; bytes
;;                              have no script-level span, so nil
;; ListStream isn't handled yet because EDN parsing wants one document,
;; not a stream of values; if a user really wants `... | lines | from edn`
;; they can pipe through `collect` first.
(defn extract-input-with-span [input]
  (cond
    (= "Empty" input)
    {:text "" :span nil}

    (and (map? input) (contains? input :Value))
    {:text (or (get-in input [:Value 0 :String :val]) "")
     :span (get-in input [:Value 0 :String :span])}

    (and (map? input) (contains? input :ByteStream))
    {:text (read-byte-stream (get-in input [:ByteStream :id]))
     :span nil}

    :else
    {:text "" :span nil}))

(defn send-error-response
  ([call-id msg] (send-error-response call-id msg []))
  ([call-id msg labels]
   (send-msg {:CallResponse
              [call-id {:Error {:msg msg :labels labels :code nil
                                :url nil :help nil :inner []}}]})))

;; Build an error label that points at the parse-error position. Returns
;; a singleton vec for use directly as the :labels field, or [] if we
;; don't have enough info to point anywhere useful (no source span, or
;; missing line/col). The span we emit is one byte wide — Nushell will
;; underline that single position in the source view.
(defn- parse-error-labels [text source-span line col]
  (if (and source-span line col (pos? line) (pos? col))
    (let [char-off (char-offset-in text line col)
          byte-off (byte-offset-of-char text char-off)
          start    (+ (:start source-span) byte-off)
          end      (min (inc start) (:end source-span))]
      [{:text "parse error here" :span {:start start :end end}}])
    []))

(defn- parse-error-message [^Throwable t]
  ;; clojure.edn wraps the inner cause in EdnReader$ReaderException;
  ;; the cause's message is the readable one ("Map literal must
  ;; contain an even number of forms" rather than
  ;; "java.lang.RuntimeException: Map literal …").
  (or (some-> (.getCause t) .getMessage)
      (.getMessage t)))

(def from-edn-sig
  {:sig {:name "from edn"
         :description "Parse text as EDN."
         :extra_description "Converts EDN-formatted text into Nushell structured values."
         :search_terms ["edn" "clojure" "parse"]
         :required_positional []
         :optional_positional []
         :rest_positional nil
         :named [{:long "help"    :short "h" :arg nil :required false
                  :desc "Display help"
                  :var_id nil :default_value nil}
                 {:long "lines"   :short "l" :arg nil :required false
                  :desc "Parse the input as a sequence of top-level EDN forms; emit each as a separate value (ListStream output)."
                  :var_id nil :default_value nil}
                 {:long "objects" :short "o" :arg nil :required false
                  :desc "Alias for --lines (mirrors `from json --objects` naming)."
                  :var_id nil :default_value nil}
                 {:long "set2record" :short nil :arg nil :required false
                  :desc "Render EDN sets as Nushell records in mirror form ({k: k} where each key equals its stringified element) instead of lists. Round-trip pair with `to edn --record2set`. Lossy for non-keyword/string set elements (Nushell record keys are strings only)."
                  :var_id nil :default_value nil}
                 {:long "keep-keyword-prefix" :short nil :arg nil :required false
                  :desc "Preserve keyword/string fidelity by keeping the leading `:` on keywords as a marker (`:foo` -> `\":foo\"`). Pair with `to edn --keep-keyword-prefix` for round-trip. Plain strings starting with `:` will coerce to keywords on the to-edn side — documented one-way fidelity loss."
                  :var_id nil :default_value nil}]
         :input_output_types [["String" "Any"]]
         :allow_variants_without_examples true
         :is_filter false :creates_scope false :allows_unknown_args false
         :category "Formats"}
   :examples
   [{:example     "'{:name \"alice\" :age 30}' | from edn"
     :description "Parse a single EDN map into a Nushell record."
     :result      nil}
    {:example     "'[{:filename \"a.txt\" :size 100} {:filename \"b.txt\" :size 200}]' | from edn"
     :description "Parse a vector of maps into a Nushell table."
     :result      nil}
    {:example     "'1 2 3 :four \"five\"' | from edn --lines"
     :description "Parse multiple top-level forms; emit each as a separate value (ListStream)."
     :result      nil}
    {:example     "bb produce.clj | from edn --lines | where status == \"active\""
     :description "Stream EDN forms from a babashka producer through the plugin and into Nushell pipeline ops."
     :result      nil}
    {:example     "^uuidv7 parse 0195a4c8-fae8-7c8d-b2a1-... | from edn | get datetime"
     :description "Cross-tool: extract the embedded timestamp from a UUIDv7 via the uuidv7 CLI + from edn."
     :result      nil}]})

(def to-edn-sig
  {:sig {:name "to edn"
         :description "Convert a Nushell value to EDN text."
         :extra_description "Records become maps with keyword keys; lists/tables become vectors. Nushell-native types without an EDN equivalent (Duration, Filesize, Binary) fall back to primitives — see README for the full table. With --lines or --objects, each input element is emitted as its own top-level form."
         :search_terms ["edn" "clojure" "serialize" "emit"]
         :required_positional []
         :optional_positional []
         :rest_positional nil
         :named [{:long "help"    :short "h" :arg nil :required false
                  :desc "Display help"
                  :var_id nil :default_value nil}
                 {:long "lines"   :short "l" :arg nil :required false
                  :desc "Emit each top-level form on its own line (newline-separated). Pairs with `from edn --lines` for streaming round-trips."
                  :var_id nil :default_value nil}
                 {:long "objects" :short "o" :arg nil :required false
                  :desc "Emit each top-level form separated by single spaces, no newlines. Compact concatenated-objects output."
                  :var_id nil :default_value nil}
                 {:long "pprint"  :short "p" :arg nil :required false
                  :desc "Pretty-print the output via clojure.pprint instead of compact pr-str. Mutually exclusive with --lines and --objects."
                  :var_id nil :default_value nil}
                 {:long "record2set" :short nil :arg nil :required false
                  :desc "If a record is in mirror form ({k: k} where every key equals its value), emit it as an EDN set instead of a map. Round-trip pair with `from edn --set2record`. Non-mirror records stay as maps."
                  :var_id nil :default_value nil}
                 {:long "keep-keyword-prefix" :short nil :arg nil :required false
                  :desc "Re-emit strings that look like keywords (start with `:`, valid name chars) as EDN keywords. Round-trip pair with `from edn --keep-keyword-prefix`. Without the pair, EDN keywords degrade to plain Nushell strings."
                  :var_id nil :default_value nil}
                 {:long "string-keys" :short nil :arg nil :required false
                  :desc "Emit record keys as EDN strings ({\"name\" \"alice\"}) instead of keywords ({:name \"alice\"}). For pipelines feeding non-Clojure EDN consumers (Python/JS/Go) that don't speak keyword keys."
                  :var_id nil :default_value nil}
                 {:long "meta" :short nil :arg "Any" :required false
                  :desc "Prefix the emitted top-level form with a Clojure-reader-style metadata map (^{...} <form>). Useful for attaching provenance/context that a bb consumer reads via (meta v). NON-PORTABLE: ^{...} is Clojure-reader syntax, not part of the EDN spec — Python/JS/Go EDN parsers will reject it. Mutually exclusive with --lines/--objects."
                  :var_id nil :default_value nil}]
         :input_output_types [["Any" "String"]]
         :allow_variants_without_examples true
         :is_filter false :creates_scope false :allows_unknown_args false
         :category "Formats"}
   :examples
   [{:example     "{name: \"alice\" age: 30} | to edn"
     :description "Emit a Nushell record as an EDN map with keyword keys."
     :result      nil}
    {:example     "[{n: 1} {n: 2} {n: 3}] | to edn"
     :description "Emit a Nushell table as a vector of EDN maps."
     :result      nil}
    {:example     "[{n: 1} {n: 2}] | to edn --lines"
     :description "Multi-form output: each list element on its own line."
     :result      nil}
    {:example     "{user: \"alice\" id: 42} | to edn | ^cedn | sha256sum"
     :description "Cross-tool: produce a deterministic content hash via the cedn CLI."
     :result      nil}
    {:example     "{user: \"alice\"} | to edn | ^cedn | from edn"
     :description "Cross-tool: canonicalize and round-trip a value through the cedn CLI."
     :result      nil}]})

(defn- send-from-edn-error [call-id text source-span line col cause]
  (send-error-response
   call-id
   (str "EDN parse error: " (parse-error-message cause))
   (parse-error-labels text source-span line col)))

(defn handle-from-edn [call-id run]
  (let [input  (:input run)
        named  (get-in run [:call :named])
        multi? (or (flag-set? named "lines")
                   (flag-set? named "objects"))]
    (binding [*set-as-record*       (flag-set? named "set2record")
              *keep-keyword-prefix* (flag-set? named "keep-keyword-prefix")]
      (cond
        ;; Multi-form mode + ByteStream  ->  truly incremental streaming.
        ;; Bytes are pulled on demand; forms are emitted as they're parsed.
        (and multi? (map? input) (contains? input :ByteStream))
        (emit-stream-incremental call-id (get-in input [:ByteStream :id]))

        ;; Multi-form mode + non-stream input (Value / Empty)  ->
        ;; buffer the string, parse all forms, emit as a ListStream.
        multi?
        (let [{:keys [text span]} (extract-input-with-span input)
              {:keys [ok err]}    (read-edn-with-pos text true)]
          (if err
            (send-from-edn-error call-id text span
                                 (:line err) (:col err) (:cause err))
            (emit-list-stream call-id ok)))

        ;; Single-form mode (default)  ->  buffered, return a single Value.
        :else
        (let [{:keys [text span]} (extract-input-with-span input)
              {:keys [ok err]}    (read-edn-with-pos text false)]
          (if err
            (send-from-edn-error call-id text span
                                 (:line err) (:col err) (:cause err))
            (send-msg {:CallResponse
                       [call-id
                        {:PipelineData {:Value [(->nu-value ok) nil]}}]})))))))

;; Collect a ListStream input into a vector of Values. The engine
;; sends {:Data [<id> {:List <value>}]} messages until {:End <id>}.
;; Used when `| where ...`, `| each ...`, etc. feeds `to edn` — those
;; commands emit ListStreams, not in-memory Values.
(defn read-list-stream [stream-id]
  (loop [acc []]
    (let [msg (pull-stream-msg stream-id nil)]
      (cond
        (nil? msg)           acc
        (contains? msg :End) acc
        (contains? msg :Data)
        (let [[_ data] (:Data msg)]
          (send-msg {:Ack stream-id})
          (recur (conj acc (:List data))))))))

(defn- emit-clj
  "Serialize a Clojure value to EDN text. Compact (`pr-str`) by default;
  pretty-printed via clojure.pprint when `pprint?` is true. pprint
  output already includes a trailing newline, which we keep."
  [v pprint?]
  (if pprint?
    (with-out-str (pprint/pprint v))
    (pr-str v)))

(defn handle-to-edn [call-id run]
  ;; Output modes, controlled by flags:
  ;;   - default     : emit ONE form (input is wrapped as-is). Vector
  ;;                   for a list/table; map for a record; etc.
  ;;   - --lines     : emit each top-level item with a trailing newline.
  ;;   - --objects   : same iteration, single space separator instead
  ;;                   of newline.
  ;;   - --pprint    : pretty-print via clojure.pprint. Single-form only;
  ;;                   mutually exclusive with --lines and --objects.
  ;;
  ;; --lines and --objects are NOT synonyms here (unlike on `from edn`,
  ;; where parsing is whitespace-agnostic). Different separator semantics.
  ;;
  ;; Content transformation is independent of layout: --record2set
  ;; converts mirror-form records to EDN sets at any nesting depth,
  ;; and combines freely with any of the layout flags above.
  (let [input    (:input run)
        named    (get-in run [:call :named])
        lines?   (flag-set? named "lines")
        objs?    (flag-set? named "objects")
        pprint?  (flag-set? named "pprint")
        meta-val (flag-value named "meta")
        multi?   (or lines? objs?)]
    (cond
      (and pprint? multi?)
      (send-error-response
       call-id
       "--pprint cannot be combined with --lines or --objects")

      (and meta-val multi?)
      (send-error-response
       call-id
       "--meta cannot be combined with --lines or --objects")

      (and meta-val (not (and (map? meta-val) (contains? meta-val :Record))))
      (send-error-response
       call-id
       "--meta requires a record value")

      (and (map? input) (contains? input :ByteStream))
      (send-error-response
       call-id
       "to edn requires a structured value or list-stream input (got raw bytes)")

      :else
      (binding [*record-as-set*       (flag-set? named "record2set")
                *keep-keyword-prefix* (flag-set? named "keep-keyword-prefix")
                *string-keys*         (flag-set? named "string-keys")]
        (try
          (let [items (cond
                        (= "Empty" input)
                        []

                        (and (map? input) (contains? input :Value))
                        (let [v (get-in input [:Value 0])]
                          (if (and multi? (contains? v :List))
                            (get-in v [:List :vals])
                            [v]))

                        (and (map? input) (contains? input :ListStream))
                        (let [vals (read-list-stream (get-in input [:ListStream :id]))]
                          (if multi?
                            vals
                            ;; Single-form mode: re-wrap as one List Value.
                            [{:List {:vals vals :span {:start 0 :end 0}}}]))

                        :else [])
                edn-str (cond
                          lines?
                          (apply str (map #(str (pr-str (nu->clj %)) "\n") items))

                          objs?
                          (apply str (map #(str (pr-str (nu->clj %)) " ") items))

                          :else
                          ;; Single-form mode preserves the original
                          ;; behaviour: Empty -> "nil", anything else
                          ;; -> serialized form of the value. With
                          ;; --meta, prefix `^<meta-edn> ` (Clojure
                          ;; reader metadata syntax — non-portable to
                          ;; non-Clojure EDN parsers).
                          (let [body (emit-clj (when-let [v (first items)] (nu->clj v))
                                               pprint?)]
                            (if meta-val
                              (str "^" (pr-str (nu->clj meta-val)) " " body)
                              body)))
                span {:start 0 :end 0}]
            (send-msg {:CallResponse
                       [call-id
                        {:PipelineData
                         {:Value [{:String {:val edn-str :span span}} nil]}}]}))
          (catch Throwable t
            (send-error-response call-id (str "EDN serialization error: " (.getMessage t)))))))))

(defn handle-call [call-id call-data]
  (cond
    (= "Metadata" call-data)
    (send-msg {:CallResponse [call-id {:Metadata {:version plugin-release}}]})

    (= "Signature" call-data)
    (send-msg {:CallResponse
               [call-id {:Signature [from-edn-sig to-edn-sig]}]})

    (and (map? call-data) (contains? call-data :Run))
    (let [run  (:Run call-data)
          name (:name run)]
      (case name
        "from edn" (handle-from-edn call-id run)
        "to edn"   (handle-to-edn call-id run)
        (send-error-response call-id (str "unknown command: " name))))

    :else
    (send-error-response call-id (str "unhandled call: " (pr-str call-data)))))

;; Main loop. Drains any Calls that the stream readers captured during
;; concurrent pipelining BEFORE pulling new messages off stdin — this
;; ensures pipelined Call(B) issued by the engine while we were
;; processing Call(A) eventually gets handled.
(defn- drain-pending-call! []
  (when-let [msg (first @pending-calls)]
    (swap! pending-calls (fn [v] (vec (rest v))))
    (let [[call-id call-data] (:Call msg)]
      (handle-call call-id call-data))
    true))

(loop []
  (if (drain-pending-call!)
    (recur)
    (let [msg  (read-msg)
          kind (classify msg)]
      (case kind
        :eof        (log "EOF")
        :goodbye    (log "Goodbye")
        :call       (let [[call-id call-data] (:Call msg)]
                      (handle-call call-id call-data)
                      (recur))
        :stream-ctl (recur)
        :unknown    (do (log "unknown msg keys:" (when (map? msg) (keys msg))) (recur))))))
