#!/usr/bin/env bb
;; nu_plugin_edn — Nushell plugin providing `from edn`.
;;
;; This is the working prototype from the design conversation. It handles
;; the protocol handshake, basic scalars, maps, vectors, sets, and lists.
;;
;; Known limitations (see CLAUDE.md for the full list):
;;   - Keywords lose round-trip fidelity: `:file` -> "file" (colon dropped).
;;     A `--keep-keyword-prefix` flag is planned for opt-in fidelity.
;;   - No `to edn` reverse direction yet
;;   - Errors don't carry source spans
;;   - No tagged-literal support beyond what edn/read-string handles natively
;;
;; Input handling:
;;   - String values (`'edn-text' | from edn`)            -> direct
;;   - ByteStream from pipes (`bb produce.clj | from edn`) -> consumed
;;     to a buffer first, then parsed. Whole-document only — the plugin
;;     waits for End before parsing, so memory grows with input size.

(require '[clojure.edn :as edn]
         '[cheshire.core :as json])

(defn log [& args]
  (binding [*out* *err*]
    (apply println "[nu_plugin_edn]" args) (flush)))

;; Step 1: declare encoding to Nushell. Format: <byte-len><encoding-name>.
;; "json" is 4 bytes, prefixed by the length byte 4.
(let [out System/out]
  (.write out (int 4))
  (.write out (.getBytes "json" "UTF-8"))
  (.flush out))

(defn send-msg [m]
  (println (json/generate-string m))
  (flush))

(defn read-msg []
  (when-let [line (read-line)]
    (json/parse-string line true)))

;; Step 2: Hello exchange. We send first.
(send-msg {:Hello {:protocol "nu-plugin"
                   :version  "0.112.2"
                   :features []}})
(let [hello (read-msg)]
  (log "got Hello:" (boolean hello)))

;; Step 3: classify incoming control messages — they're not all maps.
;; Ack and Drop messages from the engine arrive after we've finished
;; emitting a ListStream (they reference our output stream id). Treat
;; them as expected-but-ignored rather than :unknown.
(defn classify [msg]
  (cond
    (nil? msg)                                 :eof
    (= "Goodbye" msg)                          :goodbye
    (and (map? msg) (contains? msg :Call))     :call
    (and (map? msg) (contains? msg :Goodbye))  :goodbye
    (and (map? msg) (contains? msg :Ack))      :stream-ctl
    (and (map? msg) (contains? msg :Drop))     :stream-ctl
    :else                                      :unknown))

;; Convert a parsed Clojure value into Nushell's value-record shape.
;; Each leaf carries a `span` (Nushell wants source-span info even for
;; values that didn't come from source — `{:start 0 :end 0}` is fine).
(defn ->nu-value [v]
  (let [span {:start 0 :end 0}]
    (cond
      (nil? v)        {:Nothing {:span span}}
      (string? v)     {:String  {:val v :span span}}
      (boolean? v)    {:Bool    {:val v :span span}}
      (integer? v)    {:Int     {:val v :span span}}
      (float? v)      {:Float   {:val (double v) :span span}}
      (keyword? v)    {:String  {:val (subs (str v) 1) :span span}}
      (symbol? v)     {:String  {:val (str v) :span span}}
      (map? v)        {:Record  {:val (into {} (for [[k vv] v]
                                                  [(if (keyword? k) (subs (str k) 1) (str k))
                                                   (->nu-value vv)]))
                                 :span span}}
      (sequential? v) {:List    {:vals (mapv ->nu-value v) :span span}}
      (set? v)        {:List    {:vals (mapv ->nu-value v) :span span}}
      :else           {:String  {:val (pr-str v) :span span}})))

;; ByteStream input handling.
;;
;; When the user pipes an external command into `from edn`, Nushell
;; declares the input as a ByteStream (carrying a stream id) in the Run
;; call, then pushes raw bytes via subsequent `Data` messages — each
;; shaped like {:Data [<stream-id> {:Raw {:Ok [<byte-ints>...]}}]} —
;; terminated by {:End <stream-id>}. We acknowledge each chunk with
;; {:Ack <stream-id>} so the engine's backpressure window keeps moving;
;; otherwise large inputs would stall. Once we see End we decode the
;; accumulated bytes as UTF-8 and return the resulting string for
;; edn/read-string. This is a buffered approach — the entire stream
;; lands in memory before parsing — appropriate for typical config-
;; sized inputs but not for log-sized ones.
(defn read-byte-stream [stream-id]
  (let [baos (java.io.ByteArrayOutputStream.)]
    (loop []
      (let [msg (read-msg)]
        (cond
          (nil? msg)
          (.toString baos "UTF-8")

          (and (map? msg) (contains? msg :End))
          (.toString baos "UTF-8")

          (and (map? msg) (contains? msg :Data))
          (let [[id data] (:Data msg)]
            (when (= id stream-id)
              (when-let [bs (get-in data [:Raw :Ok])]
                (doseq [b bs]
                  (.write baos (int b))))
              (send-msg {:Ack stream-id}))
            (recur))

          ;; Any other interleaved message (e.g. Drop) — keep reading.
          :else (recur))))))

;; ListStream output handling (--lines / --objects mode).
;;
;; In multi-form mode we don't return a single Value; we open a ListStream
;; and push parsed forms as Data messages. This lets downstream commands
;; like `first 10` short-circuit instead of waiting for the whole input
;; to be parsed and assembled into a List.
;;
;; Stream ids must be unique within the plugin process. We allocate from
;; an atom that starts at zero — the plugin's id space is independent
;; from the engine's, since direction disambiguates the channel.
(def next-stream-id (atom 0))
(defn alloc-stream-id [] (swap! next-stream-id inc))

;; Read zero or more top-level EDN forms from a string. We deliberately
;; use form boundaries (matching brackets, quoted strings, etc.) rather
;; than newlines: EDN forms are self-delimiting, multi-line forms parse
;; correctly, and `; comments` work because edn/read strips them. The
;; tradeoff is that one giant top-level form forces the whole stream
;; into memory — but well-behaved producers emit small forms.
(defn read-all-forms [s]
  (let [reader (java.io.PushbackReader. (java.io.StringReader. s))
        eof    (Object.)]
    (loop [acc []]
      (let [v (edn/read {:eof eof} reader)]
        (if (= v eof)
          acc
          (recur (conj acc v)))))))

;; Detect a switch by name in the call's :named entries. Each entry is
;; a [{:item "name" :span ...} value] pair; we only care about presence.
(defn flag-set? [named flag-name]
  (some (fn [[k _v]] (= (:item k) flag-name)) named))

;; Emit a sequence of values as a ListStream response. Each value goes
;; out as {:Data [id {:List <nu-value>}]}, terminated by {:End id}.
;;
;; v1 limitation: we don't wait on engine Acks before sending the next
;; Data, and we don't react to Drop messages mid-stream. For moderate
;; streams the engine tolerates this; large streams may eventually need
;; backpressure. If the engine sends Drop after enough downstream
;; consumption (e.g. `| first 10`), the message will be processed in
;; the main loop after End — harmless but means we still computed and
;; sent every value. True early-termination requires interleaving stdin
;; reads with output writes, which is deferred.
(defn emit-list-stream [call-id forms]
  (let [sid  (alloc-stream-id)
        span {:start 0 :end 0}]
    (send-msg {:CallResponse
               [call-id
                {:PipelineData
                 {:ListStream {:id sid :span span :metadata nil}}}]})
    (doseq [v forms]
      (send-msg {:Data [sid {:List (->nu-value v)}]}))
    (send-msg {:End sid})))

;; Pull the EDN text out of whatever pipeline shape Nushell handed us.
;; Three shapes show up in practice:
;;   - "Empty"               — no upstream input; treat as empty string
;;   - {:Value [v meta]}      — a single in-memory Value (e.g. literal string)
;;   - {:ByteStream {:id N}}  — an external command's stdout
;; ListStream isn't handled yet because EDN parsing wants one document,
;; not a stream of values; if a user really wants `... | lines | from edn`
;; they can pipe through `collect` first.
(defn extract-input [input]
  (cond
    (= "Empty" input)
    ""

    (and (map? input) (contains? input :Value))
    (or (get-in input [:Value 0 :String :val]) "")

    (and (map? input) (contains? input :ByteStream))
    (read-byte-stream (get-in input [:ByteStream :id]))

    :else
    ""))

(defn handle-call [call-id call-data]
  (cond
    (= "Metadata" call-data)
    (send-msg {:CallResponse [call-id {:Metadata {:version "0.1.0"}}]})

    (= "Signature" call-data)
    (send-msg
      {:CallResponse
       [call-id
        {:Signature
         [{:sig {:name "from edn"
                 :description "Parse text as EDN."
                 :extra_description "Converts EDN-formatted text into Nushell structured values."
                 :search_terms ["edn" "clojure" "parse"]
                 :required_positional []
                 :optional_positional []
                 :rest_positional nil
                 :named [{:long "help"    :short "h" :arg nil :required false
                          :desc "Display help"
                          :var_id nil :default_value nil}
                         {:long "lines"   :short "l" :arg nil :required false
                          :desc "Parse the input as a sequence of top-level EDN forms; emit each as a separate value (ListStream output)."
                          :var_id nil :default_value nil}
                         {:long "objects" :short "o" :arg nil :required false
                          :desc "Alias for --lines (mirrors `from json --objects` naming)."
                          :var_id nil :default_value nil}]
                 :input_output_types [["String" "Any"]]
                 :allow_variants_without_examples true
                 :is_filter false :creates_scope false :allows_unknown_args false
                 :category "Formats"}
           :examples []}]}]})

    (and (map? call-data) (contains? call-data :Run))
    (let [run        (:Run call-data)
          input      (:input run)
          named      (get-in run [:call :named])
          multi?     (or (flag-set? named "lines")
                         (flag-set? named "objects"))
          input-str  (extract-input input)]
      (try
        (if multi?
          (emit-list-stream call-id (read-all-forms input-str))
          (let [parsed (edn/read-string input-str)]
            (send-msg {:CallResponse
                       [call-id
                        {:PipelineData {:Value [(->nu-value parsed) nil]}}]})))
        (catch Throwable t
          (send-msg {:CallResponse
                     [call-id
                      {:Error {:msg (str "EDN parse error: " (.getMessage t))
                               :labels [] :code nil :url nil :help nil :inner []}}]}))))

    :else
    (send-msg {:CallResponse
               [call-id {:Error {:msg (str "unhandled call: " (pr-str call-data))
                                 :labels [] :code nil :url nil :help nil :inner []}}]})))

;; Main loop.
(loop []
  (let [msg  (read-msg)
        kind (classify msg)]
    (case kind
      :eof        (log "EOF")
      :goodbye    (log "Goodbye")
      :call       (let [[call-id call-data] (:Call msg)]
                    (handle-call call-id call-data)
                    (recur))
      :stream-ctl (recur)
      :unknown    (do (log "unknown msg keys:" (when (map? msg) (keys msg))) (recur)))))
